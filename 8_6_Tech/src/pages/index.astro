---
import '/src/styles/global.css';
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vọc Giao Diện Thẻ Sản Phẩm</title>
  </head>
  
  <body class="min-h-screen bg-gradient-to-br from-zinc-950 via-red-950 to-black flex flex-col items-center justify-center p-6 text-white font-sans">
    <div class="bg-slate-900/80 backdrop-blur-md p-6 rounded-2xl shadow-2xl max-w-sm border border-slate-800 transition-all duration-300 hover:border-cyan-500 hover:scale-105 hover:shadow-cyan-500/20">
      
      <img 
        src="data:image/jpeg;base64," 
        alt="Smartwatch" 
        class="w-full h-48 object-cover rounded-xl mb-4 shadow-md" 
      />

      <div class="flex items-center mb-3">
        <span class="relative flex h-2 w-2 mr-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
        </span>
        <span class="bg-cyan-500/10 text-cyan-400 text-xs font-bold px-2.5 py-0.5 rounded-full uppercase tracking-wider">
          Công Nghệ Mới
        </span>
      </div>
      <!-- 3. TIÊU ĐỀ SẢN PHẨM -->
      <h2 class="text-xl font-bold text-white mb-2">
        Astro Watch v3.4
      </h2>

      <!-- 4. ĐOẠN MÔ TẢ NGẮN -->
      <p class="text-slate-400 text-sm leading-relaxed mb-5">
        Trang web được tối ưu hóa tốc độ cực đỉnh nhờ cơ chế Islands Architecture của Astro và cấu trúc mã CSS siêu nhẹ từ Tailwind.
      </p>

      <!-- 5. THANH TOÁN & NÚT HÀNH ĐỘNG -->
      <div class="flex items-center justify-between pt-2 border-t border-slate-800">
        <!-- Giá tiền -->
        <span class="text-2xl font-extrabold text-cyan-400">
          $299.00
        </span>
        
        <!-- Nút mua ngay -->
        <button class="bg-cyan-500 hover:bg-cyan-600 text-slate-950 font-bold py-2 px-4 rounded-xl transition-all shadow-md active:scale-95">
          Mua Ngay
        </button>
      </div>

    </div>

  </body>
</html>