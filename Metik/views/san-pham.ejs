<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sản phẩm - METIK</title>
  <meta name="description" content="Danh mục các sản phẩm snack METIK giòn rụm thơm ngon: Snack vị rong biển, BBQ, bắp ngọt, phô mai béo ngậy.">
  
  <link rel="icon" href="https://metik.vn/wp-content/uploads/2026/06/cropped-faviconmetik-32x32.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Header -->
  <%- include('partials/header') %>

  <!-- --- PAGE BANNER --- -->
  <section class="page-banner">
    <img src="https://metik.vn/wp-content/uploads/2021/05/banner-metik-2-1-scaled.webp" alt="Sản phẩm banner" class="page-banner-bg">
    <div class="page-banner-overlay"></div>
    <div class="page-banner-content">
      <h1 class="page-banner-title">Sản phẩm</h1>
      <nav class="breadcrumbs">
        <a href="/">Trang chủ</a>
        <span>/</span>
        <span>Sản phẩm</span>
      </nav>
    </div>
  </section>

  <!-- --- MAIN CONTENT --- -->
  <main>
    <section class="section-padding">
      <div class="container">
        
        <!-- Filter Bar -->
        <div class="shop-filter-bar">
          <div class="shop-results-count">
            Hiển thị tất cả <%= products.length %> kết quả
          </div>
          <div class="shop-sort">
            <select class="shop-sort-select" aria-label="Sắp xếp sản phẩm">
              <option value="menu_order" selected>Sắp xếp mặc định</option>
              <option value="popularity">Theo mức độ phổ biến</option>
              <option value="date">Mới nhất</option>
              <option value="name-asc">Tên: A đến Z</option>
            </select>
          </div>
        </div>
        
        <!-- Products Grid -->
        <div class="product-grid">
          <% products.forEach(product => { %>
            <article class="product-card">
              <span class="product-card-badge <%= product.badge === 'Nổi bật' || product.badge === 'Bán chạy' ? 'hot' : '' %>">
                <%= product.badge %>
              </span>
              <div class="product-card-img-wrap">
                <img src="<%= product.image %>" alt="<%= product.name %>" class="product-card-img">
              </div>
              <h3 class="product-card-title"><a href="/san-pham/<%= product.id %>"><%= product.name %></a></h3>
              <div class="product-card-tags">
                <span class="product-card-tag"><%= product.tag1 %></span>
                <span class="product-card-tag"><%= product.tag2 %></span>
              </div>
              <div class="product-card-action">
                <a href="/san-pham/<%= product.id %>" class="btn btn-outline product-card-btn">Xem chi tiết</a>
              </div>
            </article>
          <% }) %>
        </div>
        
      </div>
    </section>
  </main>

  <!-- Footer -->
  <%- include('partials/footer') %>

</body>
</html>
