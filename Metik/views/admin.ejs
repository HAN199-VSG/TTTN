<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - METIK</title>
  
  <link rel="icon" href="https://metik.vn/wp-content/uploads/2026/06/cropped-faviconmetik-32x32.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  
  <style>
    .admin-container {
      margin-top: 130px;
      margin-bottom: 80px;
    }
    .admin-card {
      background: var(--bg-white);
      border-radius: var(--radius-md);
      padding: 35px;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--border-light);
    }
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
      border-bottom: 2px solid var(--border-light);
      padding-bottom: 15px;
    }
    .admin-title {
      font-size: 1.8rem;
      color: var(--primary-color);
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .admin-stats {
      display: flex;
      gap: 20px;
      margin-bottom: 35px;
    }
    .stat-box {
      flex: 1;
      background: #fafafa;
      border-radius: var(--radius-sm);
      padding: 20px;
      border-left: 5px solid var(--primary-color);
      box-shadow: var(--shadow-sm);
    }
    .stat-box.success {
      border-left-color: var(--secondary-color);
    }
    .stat-num {
      font-size: 2.2rem;
      font-weight: 900;
      color: var(--text-dark);
      line-height: 1.2;
    }
    .stat-label {
      font-size: 0.85rem;
      color: var(--text-muted);
      text-transform: uppercase;
      font-weight: 700;
      margin-top: 4px;
    }
    .msg-table-wrap {
      overflow-x: auto;
      width: 100%;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border-light);
    }
    .msg-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 0.95rem;
    }
    .msg-table th, .msg-table td {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border-light);
    }
    .msg-table th {
      background: #f5f5f5;
      font-weight: 700;
      color: var(--text-dark);
      text-transform: uppercase;
      font-size: 0.85rem;
    }
    .msg-table tr:hover td {
      background: #fffdfa;
    }
    .msg-table tr:last-child td {
      border-bottom: none;
    }
    .msg-date {
      color: var(--text-muted);
      font-size: 0.85rem;
      white-space: nowrap;
    }
    .msg-user-name {
      font-weight: 700;
      color: var(--text-dark);
    }
    .msg-contact-info {
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.4;
    }
    .msg-text {
      max-width: 400px;
      line-height: 1.5;
      color: #444;
    }
    .btn-delete {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(235, 87, 87, 0.1);
      color: #eb5757;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: var(--transition-smooth);
    }
    .btn-delete:hover {
      background: #eb5757;
      color: white;
      transform: scale(1.1);
    }
    .empty-state {
      text-align: center;
      padding: 60px 0;
      color: var(--text-muted);
    }
    .empty-icon {
      font-size: 3rem;
      margin-bottom: 15px;
      color: #ddd;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <%- include('partials/header') %>

  <!-- --- ADMIN CONTAINER --- -->
  <div class="container admin-container">
    <div class="admin-card">
      
      <div class="admin-header">
        <h1 class="admin-title">
          <i class="fas fa-user-shield"></i> Quản trị liên hệ METIK
        </h1>
        <a href="/" class="btn btn-outline" style="padding: 8px 20px; font-size: 0.85rem;">
          <i class="fas fa-home"></i> Xem Trang chủ
        </a>
      </div>

      <!-- Stats -->
      <div class="admin-stats">
        <div class="stat-box">
          <div class="stat-num" id="total-messages-count"><%= messages.length %></div>
          <div class="stat-label">Tổng tin nhắn nhận</div>
        </div>
        <div class="stat-box success">
          <div class="stat-num"><%= products.length %></div>
          <div class="stat-label">Tổng sản phẩm đang bán</div>
        </div>
      </div>

      <!-- Message Table -->
      <div class="msg-table-wrap">
        <% if (messages.length > 0) { %>
          <table class="msg-table">
            <thead>
              <tr>
                <th>Ngày gửi</th>
                <th>Khách hàng</th>
                <th>Thông tin liên hệ</th>
                <th>Nội dung tin nhắn</th>
                <th style="text-align: center;">Hành động</th>
              </tr>
            </thead>
            <tbody id="message-list-body">
              <% messages.forEach(msg => { %>
                <tr id="row-<%= msg.id %>">
                  <td class="msg-date">
                    <%= new Date(msg.date).toLocaleString('vi-VN', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit', year: 'numeric' }) %>
                  </td>
                  <td class="msg-user-name"><%= msg.name %></td>
                  <td class="msg-contact-info">
                    <div><i class="far fa-envelope"></i> <%= msg.email %></div>
                    <div style="margin-top: 4px;"><i class="fas fa-phone-alt"></i> <%= msg.phone %></div>
                  </td>
                  <td class="msg-text"><%= msg.message %></td>
                  <td style="text-align: center;">
                    <button class="btn-delete" data-id="<%= msg.id %>" title="Xóa liên hệ này" aria-label="Xóa liên hệ">
                      <i class="far fa-trash-alt"></i>
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="empty-state">
            <div class="empty-icon"><i class="far fa-envelope-open"></i></div>
            <p>Hộp thư liên hệ đang trống. Chưa có phản hồi nào từ khách hàng.</p>
          </div>
        <% } %>
      </div>

    </div>
  </div>

  <!-- Footer -->
  <%- include('partials/footer') %>

  <!-- Admin logic -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const deleteButtons = document.querySelectorAll('.btn-delete');
      const totalCountEl = document.getElementById('total-messages-count');
      
      deleteButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const msgId = btn.dataset.id;
          if (confirm('Bạn có chắc chắn muốn xóa tin nhắn liên hệ này không?')) {
            fetch(`/api/contact/${msgId}`, {
              method: 'DELETE'
            })
            .then(res => {
              if (res.ok) {
                const row = document.getElementById(`row-${msgId}`);
                if (row) {
                  // Fade out row and remove
                  row.style.transition = 'all 0.5s ease';
                  row.style.opacity = '0';
                  row.style.transform = 'translateX(-20px)';
                  setTimeout(() => {
                    row.remove();
                    // Update count
                    if (totalCountEl) {
                      const currentCount = parseInt(totalCountEl.textContent);
                      totalCountEl.textContent = Math.max(0, currentCount - 1);
                    }
                  }, 500);
                }
              } else {
                alert('Có lỗi xảy ra khi xóa tin nhắn. Vui lòng thử lại.');
              }
            })
            .catch(err => {
              console.error(err);
              alert('Lỗi kết nối mạng, không thể xóa tin nhắn.');
            });
          }
        });
      });
    });
  </script>
</body>
</html>
