<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> - METIK</title>
  <meta name="description" content="<%= product.description.substring(0, 150) %>...">
  
  <link rel="icon" href="https://metik.vn/wp-content/uploads/2026/06/cropped-faviconmetik-32x32.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Header -->
  <%- include('partials/header') %>

  <!-- --- BREADCRUMBS BANNER --- -->
  <section class="page-banner" style="height: 200px;">
    <img src="<%= product.image %>" alt="<%= product.name %>" class="page-banner-bg">
    <div class="page-banner-overlay" style="background: rgba(0,0,0,0.65);"></div>
    <div class="page-banner-content">
      <h1 class="page-banner-title"><%= product.name %></h1>
      <nav class="breadcrumbs">
        <a href="/">Trang chủ</a>
        <span>/</span>
        <a href="/san-pham">Sản phẩm</a>
        <span>/</span>
        <span><%= product.name %></span>
      </nav>
    </div>
  </section>

  <!-- --- PRODUCT DETAIL CONTENT --- -->
  <main class="section-padding">
    <div class="container">
      
      <div class="product-detail-grid">
        <!-- Gallery Left -->
        <div class="product-detail-gallery">
          <div class="product-detail-img-main">
            <img src="<%= product.image %>" alt="<%= product.name %>">
            <div style="position: absolute; bottom: 15px; right: 15px; background: rgba(0,0,0,0.6); color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.9rem;">
              <i class="fas fa-expand"></i>
            </div>
          </div>
          <span style="font-size: 0.85rem; color: var(--text-muted); font-style: italic;"><i class="fas fa-search-plus"></i> Click vào hình ảnh để phóng to</span>
        </div>
        
        <!-- Info Right -->
        <div class="product-detail-info">
          <h1><%= product.name %></h1>
          <div class="product-detail-divider"></div>
          
          <div class="product-detail-desc">
            <p><%= product.description %></p>
          </div>
          
          <!-- Flavor Profile Widget -->
          <div class="flavor-profile-wrap">
            <h3 class="flavor-profile-title">Hương vị đặc trưng</h3>
            
            <% product.flavorProfile.forEach(metric => { %>
              <div class="flavor-metric-row">
                <div class="flavor-metric-label">
                  <span><%= metric.name %></span>
                  <span><%= metric.value %>%</span>
                </div>
                <div class="flavor-metric-bar-bg">
                  <div class="flavor-metric-bar" data-value="<%= metric.value %>"></div>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="product-detail-meta">
            <p>Danh mục: <strong>Các sản phẩm bánh METIK</strong></p>
            <p style="margin-top: 8px;">Nhà sản xuất: <strong>Nhà máy bánh số 1 OCHAO TP.HCM</strong></p>
          </div>
        </div>
      </div>

      <!-- Detail Tabs Section -->
      <section class="product-tabs-section">
        <div class="tabs-nav">
          <button class="tab-btn active" data-tab="description">Chi tiết sản phẩm</button>
          <button class="tab-btn" data-tab="ingredients">Thành phần & Bảo quan</button>
        </div>
        
        <div class="tab-content">
          <div class="tab-panel active" id="tab-description">
            <%- product.details %>
          </div>
          
          <div class="tab-panel" id="tab-ingredients">
            <%- product.ingredients %>
          </div>
        </div>
      </section>

      <!-- Related Products Section -->
      <section class="related-products-section">
        <h3 class="related-products-title">Sản phẩm liên quan</h3>
        <div class="product-grid">
          <% relatedProducts.forEach(related => { %>
            <article class="product-card">
              <span class="product-card-badge <%= related.badge === 'Nổi bật' || related.badge === 'Bán chạy' ? 'hot' : '' %>">
                <%= related.badge %>
              </span>
              <div class="product-card-img-wrap">
                <img src="<%= related.image %>" alt="<%= related.name %>" class="product-card-img">
              </div>
              <h3 class="product-card-title"><a href="/san-pham/<%= related.id %>"><%= related.name %></a></h3>
              <div class="product-card-tags">
                <span class="product-card-tag"><%= related.tag1 %></span>
                <span class="product-card-tag"><%= related.tag2 %></span>
              </div>
              <div class="product-card-action">
                <a href="/san-pham/<%= related.id %>" class="btn btn-outline product-card-btn">Xem chi tiết</a>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

    </div>
  </main>

  <!-- Footer -->
  <%- include('partials/footer') %>

</body>
</html>
